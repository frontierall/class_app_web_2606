APPS_SCRIPT_URL=YOUR_APPS_SCRIPT_WEB_APP_URL

# (선택) Google Sheets API v4 직접 사용 시
# GOOGLE_SHEET_ID=your_sheet_id_here
# GOOGLE_API_KEY=your_api_key_here

